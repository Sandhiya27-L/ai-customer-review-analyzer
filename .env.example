# Backend (set these as environment variables or in application.yml)
DB_URL=jdbc:mysql://localhost:3306/review_analyzer?createDatabaseIfNotExist=true&useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC
DB_USERNAME=root
DB_PASSWORD=your_password
JWT_SECRET=change-this-to-a-secure-256-bit-secret-key-minimum-32-characters
JWT_EXPIRATION_MS=86400000
JWT_REMEMBER_ME_EXPIRATION_MS=604800000
GEMINI_API_KEY=your_google_gemini_api_key
GEMINI_MODEL=gemini-2.5-flash
SERVER_PORT=8080

# Frontend (create frontend/.env from these)
VITE_API_BASE_URL=http://localhost:8080/api
